; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pokeemerald-godot"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
DataRegistry="*res://scripts/autoload/data_registry.gd"
PartyRuntime="*res://scripts/autoload/party_runtime.gd"
SaveService="*res://scripts/autoload/save_service.gd"
BattleEngine="*res://scripts/autoload/battle_engine.gd"
EvolutionEngine="*res://scripts/autoload/evolution_engine.gd"
EncounterEngine="*res://scripts/autoload/encounter_engine.gd"
MapRuntime="*res://scripts/autoload/map_runtime.gd"
ScriptVM="*res://scripts/autoload/script_vm.gd"
EventManager="*res://scripts/autoload/event_manager.gd"

[display]

window/size/viewport_width=240
window/size/viewport_height=160
window/size/window_width_override=720
window/size/window_height_override=480
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
2d/snap/snap_2d_transforms_to_pixel=true
