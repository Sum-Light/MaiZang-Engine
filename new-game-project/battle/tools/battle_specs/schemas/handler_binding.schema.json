{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maizang.invalid/battle/schemas/handler_binding.schema.json",
  "title": "HandlerBinding",
  "$comment": "The P2B executable validator proves the ten-digit filename matches handler_id and enforces local structure. Cross-file event/context and GDScript registry joins remain later phases. implementation_key is a registry key, never a path or Callable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "handler_id",
    "debug_key",
    "schema_version",
    "behavior_version",
    "family",
    "event_id",
    "implementation_key",
    "context_type",
    "instance_state_kind",
    "priority_source",
    "allowed_queries",
    "allowed_mutations",
    "allowed_rng_draw_ids",
    "mechanism_ids"
  ],
  "properties": {
    "artifact_kind": {"const": "HANDLER_BINDING"},
    "handler_id": {"$ref": "#/$defs/stable_id"},
    "debug_key": {"$ref": "#/$defs/debug_key"},
    "schema_version": {"$ref": "#/$defs/version"},
    "behavior_version": {"$ref": "#/$defs/version"},
    "family": {"enum": ["DAMAGE", "STATUS", "ACTION", "LIFECYCLE", "TARGETING", "ACCURACY", "CRITICAL", "ITEM", "ABILITY", "FIELD", "SIDE", "POSITION", "OUTCOME", "MODE"]},
    "event_id": {"$ref": "#/$defs/stable_id"},
    "implementation_key": {"$ref": "#/$defs/implementation_key"},
    "context_type": {"$ref": "#/$defs/type_name"},
    "instance_state_kind": {"$ref": "#/$defs/stable_key"},
    "priority_source": {"enum": ["DEFINITION", "INSTANCE", "EVENT_SCHEMA"]},
    "allowed_queries": {"$ref": "#/$defs/stable_key_set"},
    "allowed_mutations": {"$ref": "#/$defs/stable_key_set"},
    "allowed_rng_draw_ids": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/rng_draw_ref"}
    },
    "mechanism_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/stable_id"}
    }
  },
  "$defs": {
    "stable_id": {"type": "integer", "minimum": 1, "maximum": 2147483647},
    "version": {"type": "integer", "minimum": 1, "maximum": 2147483647},
    "debug_key": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$", "maxLength": 128},
    "stable_key": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*(\\.[A-Z][A-Z0-9_]*)*$", "maxLength": 160},
    "implementation_key": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 128},
    "type_name": {"type": "string", "pattern": "^(?![A-Za-z0-9_]*(?:Dictionary|Variant|Node|Resource|Callable))[A-Z][A-Za-z0-9_]*$", "maxLength": 128},
    "stable_key_set": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/stable_key"}
    },
    "rng_draw_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism_id", "draw_id"],
      "properties": {
        "mechanism_id": {"$ref": "#/$defs/stable_id"},
        "draw_id": {"$ref": "#/$defs/stable_id"}
      }
    }
  }
}
