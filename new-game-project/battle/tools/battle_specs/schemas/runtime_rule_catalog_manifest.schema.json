{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maizang.invalid/battle/schemas/runtime_rule_catalog_manifest.schema.json",
  "title": "RuntimeRuleCatalogManifest",
  "$comment": "Generated P2C runtime metadata only. Outer tables are emitted in ascending primary-ID order. Resolver phases are emitted by phase_order then phase_id; declared execution, event, formula, RNG, mutation, and command arrays retain their validated semantic order. No authoring paths, debug keys, owners, evidence, project requirements, tests, maturity, timestamps, GUIDs, definition values, Nodes, Resources, Callables, or script references are representable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_kind",
    "schema_version",
    "compiler_contract_version",
    "spec_manifest_sha256",
    "stable_id_manifest_sha256",
    "presentation_contracts_sha256",
    "mechanism_plans",
    "event_dispatch_table",
    "handler_binding_table",
    "resolver_phase_table"
  ],
  "properties": {
    "manifest_kind": {"const": "RUNTIME_RULE_CATALOG"},
    "schema_version": {"const": 1},
    "compiler_contract_version": {"const": 1},
    "spec_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "stable_id_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "presentation_contracts_sha256": {"$ref": "#/$defs/sha256"},
    "mechanism_plans": {
      "type": "array",
      "maxItems": 65535,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/mechanism_plan"}
    },
    "event_dispatch_table": {
      "type": "array",
      "maxItems": 65535,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/event_dispatch"}
    },
    "handler_binding_table": {
      "type": "array",
      "maxItems": 65535,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/runtime_handler_binding"}
    },
    "resolver_phase_table": {
      "type": "array",
      "maxItems": 65535,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/resolver_phase_plan"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "mechanism_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mechanism_id",
        "behavior_version",
        "ruleset_mode",
        "ruleset_ids",
        "feature_pack_ids",
        "entry_kind",
        "resolver_id",
        "phase_id",
        "subphase_id",
        "preconditions",
        "inputs",
        "read_set",
        "write_set",
        "history_reads",
        "history_writes",
        "counter_reads",
        "counter_writes",
        "ordering_key",
        "short_circuit",
        "reentry_policy",
        "execution_steps",
        "parameter_slots",
        "formula_stages",
        "rng_draws",
        "resolver_ids",
        "event_ids",
        "handler_ids",
        "state_op_ids",
        "command_ids",
        "presentation_cue_ids",
        "result_type",
        "mutation_contracts",
        "command_contracts",
        "error_contracts",
        "atomicity_policy"
      ],
      "properties": {
        "mechanism_id": {"$ref": "mechanism_spec.schema.json#/$defs/stable_id"},
        "behavior_version": {"$ref": "mechanism_spec.schema.json#/$defs/version"},
        "ruleset_mode": {"$ref": "mechanism_spec.schema.json#/properties/ruleset_mode"},
        "ruleset_ids": {"$ref": "mechanism_spec.schema.json#/properties/ruleset_ids"},
        "feature_pack_ids": {"$ref": "mechanism_spec.schema.json#/properties/feature_pack_ids"},
        "entry_kind": {"$ref": "mechanism_spec.schema.json#/properties/entry_kind"},
        "resolver_id": {"$ref": "mechanism_spec.schema.json#/$defs/optional_id"},
        "phase_id": {"$ref": "mechanism_spec.schema.json#/$defs/optional_id"},
        "subphase_id": {"$ref": "mechanism_spec.schema.json#/$defs/optional_id"},
        "preconditions": {"$ref": "mechanism_spec.schema.json#/properties/preconditions"},
        "inputs": {"$ref": "mechanism_spec.schema.json#/properties/inputs"},
        "read_set": {"$ref": "mechanism_spec.schema.json#/properties/read_set"},
        "write_set": {"$ref": "mechanism_spec.schema.json#/properties/write_set"},
        "history_reads": {"$ref": "mechanism_spec.schema.json#/properties/history_reads"},
        "history_writes": {"$ref": "mechanism_spec.schema.json#/properties/history_writes"},
        "counter_reads": {"$ref": "mechanism_spec.schema.json#/properties/counter_reads"},
        "counter_writes": {"$ref": "mechanism_spec.schema.json#/properties/counter_writes"},
        "ordering_key": {"$ref": "mechanism_spec.schema.json#/properties/ordering_key"},
        "short_circuit": {"$ref": "mechanism_spec.schema.json#/properties/short_circuit"},
        "reentry_policy": {"$ref": "mechanism_spec.schema.json#/properties/reentry_policy"},
        "execution_steps": {"$ref": "mechanism_spec.schema.json#/properties/execution_steps"},
        "parameter_slots": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/runtime_parameter_slot"}
        },
        "formula_stages": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/runtime_formula_stage"}
        },
        "rng_draws": {"$ref": "mechanism_spec.schema.json#/properties/rng_draws"},
        "resolver_ids": {"$ref": "mechanism_spec.schema.json#/properties/resolver_ids"},
        "event_ids": {"$ref": "mechanism_spec.schema.json#/properties/event_ids"},
        "handler_ids": {"$ref": "mechanism_spec.schema.json#/properties/handler_ids"},
        "state_op_ids": {"$ref": "mechanism_spec.schema.json#/properties/state_op_ids"},
        "command_ids": {"$ref": "mechanism_spec.schema.json#/properties/command_ids"},
        "presentation_cue_ids": {"$ref": "mechanism_spec.schema.json#/properties/presentation_cue_ids"},
        "result_type": {"$ref": "mechanism_spec.schema.json#/properties/result_type"},
        "mutation_contracts": {"$ref": "mechanism_spec.schema.json#/properties/mutation_contracts"},
        "command_contracts": {"$ref": "mechanism_spec.schema.json#/properties/command_contracts"},
        "error_contracts": {"$ref": "mechanism_spec.schema.json#/properties/error_contracts"},
        "atomicity_policy": {"$ref": "mechanism_spec.schema.json#/properties/atomicity_policy"}
      }
    },
    "runtime_parameter_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot_id", "value_kind", "stable_domain", "minimum", "maximum", "unit", "source_kind", "required"],
      "properties": {
        "slot_id": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/slot_id"},
        "value_kind": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/value_kind"},
        "stable_domain": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/stable_domain"},
        "minimum": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/minimum"},
        "maximum": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/maximum"},
        "unit": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/unit"},
        "source_kind": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/source_kind"},
        "required": {"$ref": "mechanism_spec.schema.json#/$defs/parameter_slot/properties/required"}
      }
    },
    "runtime_formula_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "operation",
        "operand_slot_ids",
        "operand_units",
        "output_slot_id",
        "result_unit",
        "intermediate_width_bits",
        "negative_value_policy",
        "result_minimum",
        "result_maximum",
        "parameter_slot_ids",
        "modifier_event_id",
        "modifier_aggregation",
        "rounding_mode",
        "rounding_schedule",
        "operation_order",
        "clamp_min_source",
        "clamp_max_source",
        "overflow_policy",
        "divide_by_zero_policy",
        "trace_field_keys"
      ],
      "properties": {
        "stage_id": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/stage_id"},
        "operation": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/operation"},
        "operand_slot_ids": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/operand_slot_ids"},
        "operand_units": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/operand_units"},
        "output_slot_id": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/output_slot_id"},
        "result_unit": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/result_unit"},
        "intermediate_width_bits": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/intermediate_width_bits"},
        "negative_value_policy": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/negative_value_policy"},
        "result_minimum": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/result_minimum"},
        "result_maximum": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/result_maximum"},
        "parameter_slot_ids": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/parameter_slot_ids"},
        "modifier_event_id": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/modifier_event_id"},
        "modifier_aggregation": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/modifier_aggregation"},
        "rounding_mode": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/rounding_mode"},
        "rounding_schedule": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/rounding_schedule"},
        "operation_order": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/operation_order"},
        "clamp_min_source": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/clamp_min_source"},
        "clamp_max_source": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/clamp_max_source"},
        "overflow_policy": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/overflow_policy"},
        "divide_by_zero_policy": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/divide_by_zero_policy"},
        "trace_field_keys": {"$ref": "mechanism_spec.schema.json#/$defs/formula_stage/properties/trace_field_keys"}
      }
    },
    "event_dispatch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "behavior_version",
        "context_type",
        "readable_fields",
        "writable_operations",
        "aggregation_policy",
        "sort_key",
        "short_circuit_rule",
        "nested_event_ids",
        "same_instance_recall_policy",
        "maximum_same_instance_recalls",
        "activation_visibility",
        "removal_visibility",
        "rounding_stage_refs",
        "rounding_mode",
        "rounding_schedule",
        "trace_policy"
      ],
      "properties": {
        "event_id": {"$ref": "event_schema.schema.json#/$defs/stable_id"},
        "behavior_version": {"$ref": "event_schema.schema.json#/$defs/version"},
        "context_type": {"$ref": "event_schema.schema.json#/properties/context_type"},
        "readable_fields": {"$ref": "event_schema.schema.json#/properties/readable_fields"},
        "writable_operations": {"$ref": "event_schema.schema.json#/properties/writable_operations"},
        "aggregation_policy": {"$ref": "event_schema.schema.json#/properties/aggregation_policy"},
        "sort_key": {"$ref": "event_schema.schema.json#/properties/sort_key"},
        "short_circuit_rule": {"$ref": "event_schema.schema.json#/properties/short_circuit_rule"},
        "nested_event_ids": {"$ref": "event_schema.schema.json#/properties/nested_event_ids"},
        "same_instance_recall_policy": {"$ref": "event_schema.schema.json#/properties/same_instance_recall_policy"},
        "maximum_same_instance_recalls": {"$ref": "event_schema.schema.json#/properties/maximum_same_instance_recalls"},
        "activation_visibility": {"$ref": "event_schema.schema.json#/properties/activation_visibility"},
        "removal_visibility": {"$ref": "event_schema.schema.json#/properties/removal_visibility"},
        "rounding_stage_refs": {"$ref": "event_schema.schema.json#/properties/rounding_stage_refs"},
        "rounding_mode": {"$ref": "event_schema.schema.json#/properties/rounding_mode"},
        "rounding_schedule": {"$ref": "event_schema.schema.json#/properties/rounding_schedule"},
        "trace_policy": {"$ref": "event_schema.schema.json#/properties/trace_policy"}
      }
    },
    "runtime_handler_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handler_id",
        "behavior_version",
        "family",
        "event_id",
        "implementation_key",
        "context_type",
        "instance_state_kind",
        "priority_source",
        "allowed_queries",
        "allowed_mutations",
        "allowed_rng_draw_ids",
        "mechanism_ids"
      ],
      "properties": {
        "handler_id": {"$ref": "handler_binding.schema.json#/$defs/stable_id"},
        "behavior_version": {"$ref": "handler_binding.schema.json#/$defs/version"},
        "family": {"$ref": "handler_binding.schema.json#/properties/family"},
        "event_id": {"$ref": "handler_binding.schema.json#/properties/event_id"},
        "implementation_key": {"$ref": "handler_binding.schema.json#/properties/implementation_key"},
        "context_type": {"$ref": "handler_binding.schema.json#/properties/context_type"},
        "instance_state_kind": {"$ref": "handler_binding.schema.json#/properties/instance_state_kind"},
        "priority_source": {"$ref": "handler_binding.schema.json#/properties/priority_source"},
        "allowed_queries": {"$ref": "handler_binding.schema.json#/properties/allowed_queries"},
        "allowed_mutations": {"$ref": "handler_binding.schema.json#/properties/allowed_mutations"},
        "allowed_rng_draw_ids": {"$ref": "handler_binding.schema.json#/properties/allowed_rng_draw_ids"},
        "mechanism_ids": {"$ref": "handler_binding.schema.json#/properties/mechanism_ids"}
      }
    },
    "resolver_phase_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolver_id",
        "behavior_version",
        "input_type",
        "output_type",
        "phases",
        "legal_event_emissions",
        "allowed_nested_resolver_ids",
        "mutation_services",
        "interruption_points",
        "error_semantics",
        "termination_behavior",
        "mechanism_ids"
      ],
      "properties": {
        "resolver_id": {"$ref": "resolver_spec.schema.json#/$defs/stable_id"},
        "behavior_version": {"$ref": "resolver_spec.schema.json#/$defs/version"},
        "input_type": {"$ref": "resolver_spec.schema.json#/properties/input_type"},
        "output_type": {"$ref": "resolver_spec.schema.json#/properties/output_type"},
        "phases": {
          "$comment": "Compiler order is phase_order ascending then phase_id ascending; phase debug_key is deliberately absent.",
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/runtime_resolver_phase"}
        },
        "legal_event_emissions": {"$ref": "resolver_spec.schema.json#/properties/legal_event_emissions"},
        "allowed_nested_resolver_ids": {"$ref": "resolver_spec.schema.json#/properties/allowed_nested_resolver_ids"},
        "mutation_services": {"$ref": "resolver_spec.schema.json#/properties/mutation_services"},
        "interruption_points": {"$ref": "resolver_spec.schema.json#/properties/interruption_points"},
        "error_semantics": {"$ref": "resolver_spec.schema.json#/properties/error_semantics"},
        "termination_behavior": {"$ref": "resolver_spec.schema.json#/properties/termination_behavior"},
        "mechanism_ids": {"$ref": "resolver_spec.schema.json#/properties/mechanism_ids"}
      }
    },
    "runtime_resolver_phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_id",
        "phase_order",
        "subphase_ids",
        "entry_invariants",
        "exit_invariants",
        "reentry_policy",
        "maximum_reentries",
        "mechanism_ids"
      ],
      "properties": {
        "phase_id": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/phase_id"},
        "phase_order": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/phase_order"},
        "subphase_ids": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/subphase_ids"},
        "entry_invariants": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/entry_invariants"},
        "exit_invariants": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/exit_invariants"},
        "reentry_policy": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/reentry_policy"},
        "maximum_reentries": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/maximum_reentries"},
        "mechanism_ids": {"$ref": "resolver_spec.schema.json#/$defs/phase/properties/mechanism_ids"}
      }
    }
  }
}
