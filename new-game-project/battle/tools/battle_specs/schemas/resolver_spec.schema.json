{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maizang.invalid/battle/schemas/resolver_spec.schema.json",
  "title": "ResolverSpec",
  "$comment": "The P2B executable validator proves the ten-digit filename matches resolver_id and enforces local phase and emission ordering. Cross-file reference compilation remains P2C. No call stack, iterator, path, or Callable is authoring data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_kind",
    "resolver_id",
    "debug_key",
    "schema_version",
    "behavior_version",
    "owner_module",
    "input_type",
    "output_type",
    "phases",
    "legal_event_emissions",
    "allowed_nested_resolver_ids",
    "mutation_services",
    "interruption_points",
    "error_semantics",
    "termination_behavior",
    "mechanism_ids"
  ],
  "properties": {
    "artifact_kind": {"const": "RESOLVER_SPEC"},
    "resolver_id": {"$ref": "#/$defs/stable_id"},
    "debug_key": {"$ref": "#/$defs/debug_key"},
    "schema_version": {"$ref": "#/$defs/version"},
    "behavior_version": {"$ref": "#/$defs/version"},
    "owner_module": {"$ref": "#/$defs/stable_key"},
    "input_type": {"$ref": "#/$defs/type_name"},
    "output_type": {"$ref": "#/$defs/type_name"},
    "phases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/phase"}
    },
    "legal_event_emissions": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/event_emission"}
    },
    "allowed_nested_resolver_ids": {"$ref": "#/$defs/stable_id_set"},
    "mutation_services": {"$ref": "#/$defs/stable_key_set"},
    "interruption_points": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/interruption_point"}
    },
    "error_semantics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/error_semantic"}
    },
    "termination_behavior": {"$ref": "#/$defs/termination_behavior"},
    "mechanism_ids": {
      "$comment": "Resolver-wide direct and indirect mechanism ownership. Every phase mechanism must appear here, but this set is not required to equal the union of scheduled phase members.",
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/stable_id"}
    }
  },
  "$defs": {
    "stable_id": {"type": "integer", "minimum": 1, "maximum": 2147483647},
    "optional_id": {"type": "integer", "minimum": 0, "maximum": 2147483647},
    "version": {"type": "integer", "minimum": 1, "maximum": 2147483647},
    "debug_key": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$", "maxLength": 128},
    "stable_key": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*(\\.[A-Z][A-Z0-9_]*)*$", "maxLength": 160},
    "type_name": {"type": "string", "pattern": "^(?![A-Za-z0-9_]*(?:Dictionary|Variant|Node|Resource|Callable))[A-Z][A-Za-z0-9_]*$", "maxLength": 128},
    "stable_id_set": {
      "type": "array",
      "maxItems": 512,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/stable_id"}
    },
    "stable_key_set": {
      "type": "array",
      "maxItems": 128,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/stable_key"}
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase_id", "phase_order", "debug_key", "subphase_ids", "entry_invariants", "exit_invariants", "reentry_policy", "maximum_reentries", "mechanism_ids"],
      "properties": {
        "phase_id": {"$ref": "#/$defs/stable_id"},
        "phase_order": {"type": "integer", "minimum": 1, "maximum": 128},
        "debug_key": {"$ref": "#/$defs/debug_key"},
        "subphase_ids": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stable_id"}
        },
        "entry_invariants": {"$ref": "#/$defs/stable_key_set"},
        "exit_invariants": {"$ref": "#/$defs/stable_key_set"},
        "reentry_policy": {"enum": ["DENY", "ALLOW_ONCE", "ALLOW_BOUNDED", "RESUME_ONLY"]},
        "maximum_reentries": {"type": "integer", "minimum": 0, "maximum": 64},
        "mechanism_ids": {
          "$comment": "Mechanisms scheduled in this phase; this array is a subset of resolver-level mechanism_ids.",
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stable_id"}
        }
      }
    },
    "event_emission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase_id", "event_id", "emission_point", "nested_policy", "maximum_nested_depth"],
      "properties": {
        "phase_id": {"$ref": "#/$defs/stable_id"},
        "event_id": {"$ref": "#/$defs/stable_id"},
        "emission_point": {"enum": ["BEFORE_PHASE", "DURING_PHASE", "AFTER_PHASE", "ON_ERROR", "ON_TERMINATION"]},
        "nested_policy": {"enum": ["DENY", "ALLOW_DECLARED_ONLY", "ALLOW_BOUNDED"]},
        "maximum_nested_depth": {"type": "integer", "minimum": 0, "maximum": 64}
      },
      "allOf": [
        {
          "if": {"properties": {"nested_policy": {"const": "DENY"}}, "required": ["nested_policy"]},
          "then": {"properties": {"maximum_nested_depth": {"const": 0}}}
        },
        {
          "if": {"properties": {"nested_policy": {"const": "ALLOW_DECLARED_ONLY"}}, "required": ["nested_policy"]},
          "then": {"properties": {"maximum_nested_depth": {"const": 1}}}
        },
        {
          "if": {"properties": {"nested_policy": {"const": "ALLOW_BOUNDED"}}, "required": ["nested_policy"]},
          "then": {"properties": {"maximum_nested_depth": {"minimum": 2}}}
        }
      ]
    },
    "interruption_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["interruption_id", "phase_id", "safe_boundary", "resume_phase_id", "request_owner"],
      "properties": {
        "interruption_id": {"$ref": "#/$defs/stable_id"},
        "phase_id": {"$ref": "#/$defs/stable_id"},
        "safe_boundary": {"enum": ["EVENT_STACK_EMPTY", "PHASE_COMMITTED", "COMMAND_BATCH_SEALED"]},
        "resume_phase_id": {"$ref": "#/$defs/stable_id"},
        "request_owner": {"enum": ["ACTOR", "SIDE", "APPLICATION"]}
      }
    },
    "error_semantic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error_code", "phase_id", "state_policy", "termination_policy"],
      "properties": {
        "error_code": {"$ref": "#/$defs/stable_key"},
        "phase_id": {"$ref": "#/$defs/optional_id"},
        "state_policy": {"enum": ["UNCHANGED", "PRIOR_ATOMIC_GROUPS_RETAINED", "TERMINAL_ERROR_STATE"]},
        "termination_policy": {"enum": ["CONTINUE", "ABORT_RESOLVER", "END_BATTLE_ERROR"]}
      }
    },
    "termination_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normal_result", "error_result", "terminal_state", "pending_input_policy"],
      "properties": {
        "normal_result": {"$ref": "#/$defs/stable_key"},
        "error_result": {"$ref": "#/$defs/stable_key"},
        "terminal_state": {"enum": ["NONE", "BATTLE_ENDED", "ERROR_ENDED"]},
        "pending_input_policy": {"enum": ["FORBIDDEN", "DECLARED_INTERRUPTION_ONLY"]}
      }
    }
  }
}
