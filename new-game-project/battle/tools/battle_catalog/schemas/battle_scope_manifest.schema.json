{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maizang.invalid/battle/schemas/battle_scope_manifest.schema.json",
  "title": "BattleScopeManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_kind",
    "scope_id",
    "target_data_generation",
    "rule_behavior_version",
    "compatibility_policy",
    "data_domains",
    "ruleset_families",
    "action_kinds",
    "source_classes",
    "scope_dispositions",
    "deferred_capabilities",
    "presentation_policy",
    "local_data_policy"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "manifest_kind": {"const": "BATTLE_SCOPE"},
    "scope_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "target_data_generation": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
    "rule_behavior_version": {"type": "integer", "minimum": 1},
    "compatibility_policy": {"const": "EXACT_SCOPE_CATALOG_RULE_HASH"},
    "data_domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["SPECIES", "FORM", "TYPE", "MOVE", "ABILITY", "ITEM", "GROWTH", "LEARNSET", "EGG", "EVOLUTION", "RULE_METADATA"]}
    },
    "ruleset_families": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["STANDARD_SINGLE", "STANDARD_DOUBLE", "WILD", "TRAINER", "FACILITY", "RAID", "LOCAL_SPECIAL_FEATURE_PACK"]}
    },
    "action_kinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["FIGHT", "ITEM", "SWITCH", "ESCAPE", "SKIP", "CANNOT_ACT", "REVIVE", "CHEER", "ROOTING", "EXTRA_ACTION"]}
    },
    "source_classes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "allowed_use"],
        "properties": {
          "kind": {"enum": ["AUTHORING_DATA", "PUBLIC_BEHAVIOR_EVIDENCE", "PROJECT_DECISION", "SYNTHETIC_FIXTURE"]},
          "allowed_use": {"type": "string", "minLength": 1}
        }
      }
    },
    "scope_dispositions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": {"enum": ["IMPLEMENT", "MERGED_INTO_OTHER_MECHANISM", "DEFERRED_N0", "TEXT_ONLY", "OUT_OF_SCOPE_PRESENTATION", "REJECTED_UNVERIFIED", "NOT_APPLICABLE"]}
    },
    "deferred_capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}
    },
    "presentation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_mode", "out_of_scope", "required_text_fallback"],
      "properties": {
        "runtime_mode": {"const": "TEXT_ONLY"},
        "out_of_scope": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["MODEL", "TEXTURE", "ANIMATION", "AUDIO", "BATTLE_CAMERA", "PRODUCTION_HUD"]}
        },
        "required_text_fallback": {"const": true}
      }
    },
    "local_data_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_root", "normalized_root", "runtime_root", "generated_root", "production_requires_licensed_records", "missing_license_policy"],
      "properties": {
        "source_root": {"const": "local_data/source"},
        "normalized_root": {"const": "local_data/normalized"},
        "runtime_root": {"const": "local_data/runtime"},
        "generated_root": {"const": "generated"},
        "production_requires_licensed_records": {"const": true},
        "missing_license_policy": {"const": "FAIL_PRODUCTION_ALLOW_SYNTHETIC"}
      }
    }
  }
}
