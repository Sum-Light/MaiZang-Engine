{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maizang.invalid/battle/schemas/implementation_work_item.schema.json",
  "title": "ImplementationWorkItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_item_id",
    "godot_contract_refs",
    "source_evidence_refs",
    "source_test_evidence_refs",
    "licensed_data_refs",
    "mechanism_ids",
    "coverage_targets",
    "target_godot_types",
    "fixture_ids",
    "presentation_cue_ids",
    "known_ambiguities",
    "completion_status"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "work_item_id": {"type": "string", "pattern": "^[A-Z0-9_.-]+$"},
    "godot_contract_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/godot_contract_ref"}
    },
    "source_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/source_evidence_ref"}
    },
    "source_test_evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/source_evidence_ref"}
    },
    "licensed_data_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z0-9_.-]+$"}},
    "mechanism_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "coverage_targets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mechanism_id", "branch_id"],
        "properties": {
          "mechanism_id": {"type": "integer", "minimum": 1},
          "branch_id": {"type": "integer", "minimum": 1}
        }
      }
    },
    "target_godot_types": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"}},
    "fixture_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "presentation_cue_ids": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "known_ambiguities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "completion_status": {"enum": ["NOT_STARTED", "SPECIFIED", "IMPORTED", "BOUND", "IMPLEMENTED", "VERIFIED", "RELEASED", "BLOCKED_SOURCE", "REJECTED_UNVERIFIED", "DEFERRED_N0", "OUT_OF_SCOPE_PRESENTATION", "MERGED_INTO_OTHER_MECHANISM"]}
  },
  "$defs": {
    "godot_contract_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "section", "sha256"],
      "properties": {
        "document": {"type": "string", "pattern": "^[0-9A-Za-z_.-]+\\.md$"},
        "section": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "source_evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "source_repository", "relative_path", "symbol", "sha256"],
      "properties": {
        "source_kind": {"enum": ["SOURCE_CODE", "SOURCE_SCHEMA", "SOURCE_TEST", "PROJECT_DECISION"]},
        "source_repository": {"enum": ["battlelogic", "pokelib", "MaiZangEngine"]},
        "relative_path": {"type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:[\\\\/])(?![/\\\\]).+$"},
        "symbol": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
