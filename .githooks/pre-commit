#!/bin/sh
set -eu

root="$(git rev-parse --show-toplevel)"
staged="$(git diff --cached --name-only --diff-filter=ACMRD)"

if printf '%s\n' "$staged" | grep -Eq '^(generated/|\.work/|new-game-project/assets/platinum/|new-game-project/captures/)'; then
  echo "ERROR: generated or proprietary assets must not be committed." >&2
  exit 1
fi

functional="$(printf '%s\n' "$staged" | grep -Ev '^(wiki/|\.codex/skills/maizang-engine-godot/)' || true)"
if [ -n "$functional" ] && ! printf '%s\n' "$staged" | grep -qx 'wiki/Change-Log.md'; then
  echo "ERROR: functional commits must update wiki/Change-Log.md." >&2
  exit 1
fi

powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$root/tools/update_project_memory.ps1" -ProjectRoot "$root" -Stage
