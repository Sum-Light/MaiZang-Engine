  "texts": {
    "EverGrandeCity_SidneysRoom_Text_IntroSpeech": {
      "label": "EverGrandeCity_SidneysRoom_Text_IntroSpeech",
      "line": 67,
      "source_file": "data/maps/EverGrandeCity_SidneysRoom/scripts.inc",
      "raw_text": "欢迎你，挑战者！\\n我是四天王中的花月。\\p我喜欢你的神情。\\n我猜这会是一场精彩的战斗吧。\\l很好！看起来很棒！\\p好！让我们还有你们，来一起好好享受\\n只有在宝可梦联盟才能体验的对战吧！$",
