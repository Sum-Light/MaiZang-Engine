    "CeruleanCity_Mart_Text_RepelWorksOnWeakMons": {
      "label": "CeruleanCity_Mart_Text_RepelWorksOnWeakMons",
      "line": 37,
      "source_file": "data/maps/CeruleanCity_Mart_Frlg/scripts.inc",
      "raw_text": "除虫喷雾不仅使虫属性的无法接近，\\n还会作用于弱小的宝可梦。\\p把你最强的宝可梦放在\\n宝可梦列表的最左边。\\p如果你的第一只宝可梦很强。\\n除虫喷雾的作用就会更明显。$",
