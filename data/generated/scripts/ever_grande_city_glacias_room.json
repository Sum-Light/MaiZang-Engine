  "texts": {
    "EverGrandeCity_GlaciasRoom_Text_IntroSpeech": {
      "label": "EverGrandeCity_GlaciasRoom_Text_IntroSpeech",
      "line": 61,
      "source_file": "data/maps/EverGrandeCity_GlaciasRoom/scripts.inc",
      "raw_text": "欢迎您。我叫波妮，\\n是四天王的一员。\\p我千里迢迢来到丰缘\\n磨砺我的冰属性技巧。\\p但是我在这儿见到的尽是些\\n弱不禁风的训练家和宝可梦。\\p您又如何呢？\\p要是能让我使出全力也没问题，\\n那就太棒了……！$",
